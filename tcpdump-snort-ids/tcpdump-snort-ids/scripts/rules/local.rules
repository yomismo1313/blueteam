# ==============================================================
# local.rules
# --------------------------------------------------------------
# Reglas locales de Snort para el laboratorio de detección.
# Ubicación habitual: /etc/snort/rules/local.rules
# ==============================================================

# Detecta cualquier tráfico ICMP (ping, echo request/reply)
alert icmp any any -> $HOME_NET any (msg:"ICMP Ping detected"; sid:1000001; rev:1;)

# Detecta paquetes TCP con flag SYN, típico de escaneos de puertos
alert tcp any any -> $HOME_NET any (flags:S; msg:"Possible SYN scan"; sid:1000002; rev:1;)

# Detecta cualquier paquete ARP (resolución de direcciones MAC/IP)
alert arp any any -> any any (msg:"ARP packet detected"; sid:1000003; rev:1;)

# Ejemplo de regla para detectar tráfico potencialmente malicioso
# (patrón de bytes NOP x90, habitual en shellcodes/exploits)
alert tcp $HOME_NET any -> $EXTERNAL_NET any (msg:"POSIBLE EXPLOIT"; content:"|90 90 90|"; sid:1000004; rev:1;)

# Ejemplo de regla para detectar tráfico HTTP saliente con método GET
alert tcp any any -> any 80 (msg:"TRAFICO HTTP"; content:"GET"; sid:1000005; rev:1;)
